---
import type { ExperienceProps } from "@types";
interface Props extends ExperienceProps {
  lang: "fr" | "en";
}

const { company, position, startDate, summary } = Astro.props;
---

<div class="group relative mb-8 animate-on-scroll">
  <!-- Left border accent -->
  <div class="absolute -left-5 top-0 h-full w-px bg-[#1e2d3d] transition-colors duration-300 group-hover:bg-primary"></div>

  <div class="rounded-xl border border-[#1e2d3d] bg-[#0d1620] p-6 transition-all duration-300 hover:border-primary/30 hover:shadow-[0_0_40px_rgba(240,118,33,0.05)]">
    <!-- Header -->
    <div class="mb-5 flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h3 class="font-serif text-xl font-semibold text-white">
          {company}
        </h3>
        <h4 class="font-serif text-lg font-medium text-primary">
          {position}
        </h4>
      </div>
      <span class="mt-1 shrink-0 font-mono text-xs text-neutral sm:mt-0">
        {startDate}
      </span>
    </div>

    <!-- Summary -->
    <ul class="space-y-2.5">
      {
        summary.map((log) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-neutral">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary"></span>
            {log}
          </li>
        ))
      }
    </ul>
  </div>
</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add("visible")),
    { threshold: 0.1 }
  );
  document.querySelectorAll(".animate-on-scroll").forEach(el => observer.observe(el));
</script>
