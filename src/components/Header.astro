---
import Menu from "@icons/Menu.astro";
import { Image } from "astro:assets";
import type { HeaderProps } from "@types";
import { t } from "../locales";

type Props = HeaderProps;

const { siteLogo, lang } = Astro.props;
---

<header
  class="sticky top-0 z-50 mx-auto flex max-w-5xl animate-slide-in items-center justify-between px-5 py-5"
  id="main-header"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 -z-10 rounded-b-2xl border-b border-[#1e2d3d]/60 bg-[#08101a]/85 backdrop-blur-md"></div>

  <!-- Logo -->
  <a href="/" aria-label="Home link" class="group flex items-center gap-3">
    <div class="relative">
      <Image
        class="rounded-full ring-2 ring-transparent transition-all duration-300 group-hover:ring-primary/50"
        src={siteLogo}
        width="40"
        height="40"
        alt="portfolio logo"
      />
      <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full bg-primary ring-2 ring-[#08101a]"></span>
    </div>
    <span class="hidden font-serif text-sm font-semibold text-white sm:block">SK</span>
  </a>

  <!-- Mobile controls -->
  <div class="flex items-center gap-3 sm:hidden">
    <div class="relative">
      <select
        class="appearance-none rounded-lg border border-[#1e2d3d] bg-[#0d1620] px-3 py-1.5 text-xs text-neutral focus:outline-none focus:ring-1 focus:ring-primary/50"
        onchange="window.location.href = this.value"
        aria-label="Language selector"
      >
        <option value="/" selected={lang === "fr"}>🇫🇷 FR</option>
        <option value="/en" selected={lang === "en"}>🇬🇧 EN</option>
      </select>
    </div>
    <button
      type="button"
      id="menu-button"
      class="rounded-lg border border-[#1e2d3d] p-2 text-neutral transition-colors hover:border-primary/40 hover:text-white"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <Menu />
    </button>
  </div>

  <!-- Desktop nav -->
  <nav
    class="absolute top-[4.5rem] right-5 hidden rounded-xl border border-[#1e2d3d] bg-[#0d1620]/95 px-4 py-4 backdrop-blur-md sm:static sm:flex sm:items-center sm:gap-2 sm:border-0 sm:bg-transparent sm:p-0"
    id="main-menu"
  >
    <ul class="gap-1 sm:flex">
      {[
        { href: "#experience", label: t(lang).site.nav.experience },
        { href: "#projects", label: t(lang).site.nav.projects },
        { href: "#about", label: t(lang).site.nav.about },
      ].map(({ href, label }) => (
        <li>
          <a
            class="nav-item relative block rounded-lg px-3 py-2 text-sm font-medium text-neutral transition-all duration-300 hover:bg-[#1e2d3d]/50 hover:text-white"
            href={href}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-3 border-t border-[#1e2d3d] pt-3 sm:mt-0 sm:ml-4 sm:border-l sm:border-t-0 sm:pl-4 sm:pt-0">
      <select
        class="appearance-none rounded-lg border border-[#1e2d3d] bg-[#0d1620] px-3 py-1.5 text-xs text-neutral focus:outline-none focus:ring-1 focus:ring-primary/50"
        onchange="window.location.href = this.value"
        aria-label="Language selector"
      >
        <option value="/" selected={lang === "fr"}>🇫🇷 FR</option>
        <option value="/en" selected={lang === "en"}>🇬🇧 EN</option>
      </select>
    </div>
  </nav>
</header>

<script>
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#main-menu");
  const navItems = document.querySelectorAll("#main-menu > ul > li > a");

  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    button?.setAttribute("aria-expanded", `${!isHidden}`);
  };

  button?.addEventListener("click", toggleMenu);
  navItems.forEach((item) => item?.addEventListener("click", toggleMenu));

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            const isActive = item.getAttribute("href") === `#${entry.target.id}`;
            item.classList.toggle("text-white", isActive);
            item.classList.toggle("text-neutral", !isActive);
          });
        }
      });
    },
    { threshold: 0.4 }
  );

  document.querySelectorAll("section[id]").forEach((s) => observer.observe(s));
</script>

<style>
  header { animation-timeline: scroll(); animation-range: 0 650px; }
</style>
