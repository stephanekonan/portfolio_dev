---
import { t } from "../locales";

interface Props {
  lang: "fr" | "en";
}

const { lang } = Astro.props;
const contact = t(lang).contact;
---

<section class="relative border-t border-[#1e2d3d] py-24">
  <div class="mx-auto max-w-xl px-5">

    <!-- Header -->
    <div class="mb-12 animate-on-scroll">
      <div class="mb-4 flex items-center gap-4">
        <span class="h-px w-8 bg-primary"></span>
        <h2 class="font-serif text-4xl font-bold tracking-tighter text-white md:text-5xl">
          {contact.title}
        </h2>
      </div>
      <p class="mt-2 text-sm leading-relaxed text-neutral">{contact.subtitle}</p>
    </div>

    <form id="contact-form" class="space-y-5 animate-on-scroll delay-1" action="/api/contact" method="POST">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="flex flex-col gap-2">
          <label for="name" class="text-xs font-medium text-neutral">
            {contact.name} <span class="text-primary">{contact.required}</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="rounded-xl border border-[#1e2d3d] bg-[#0d1620] px-4 py-3 text-sm text-white placeholder-neutral/40 transition-colors focus:border-primary/50 focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label for="email" class="text-xs font-medium text-neutral">
            {contact.email} <span class="text-primary">{contact.required}</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="rounded-xl border border-[#1e2d3d] bg-[#0d1620] px-4 py-3 text-sm text-white placeholder-neutral/40 transition-colors focus:border-primary/50 focus:outline-none"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="subject" class="text-xs font-medium text-neutral">
          {contact.subject} <span class="text-primary">{contact.required}</span>
        </label>
        <input
          type="text"
          id="subject"
          name="subject"
          required
          class="rounded-xl border border-[#1e2d3d] bg-[#0d1620] px-4 py-3 text-sm text-white placeholder-neutral/40 transition-colors focus:border-primary/50 focus:outline-none"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="message" class="text-xs font-medium text-neutral">
          {contact.message} <span class="text-primary">{contact.required}</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="resize-none rounded-xl border border-[#1e2d3d] bg-[#0d1620] px-4 py-3 text-sm text-white placeholder-neutral/40 transition-colors focus:border-primary/50 focus:outline-none"
        ></textarea>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="group flex w-full cursor-pointer items-center justify-center gap-2.5 rounded-xl bg-primary px-8 py-4 text-sm font-semibold text-white transition-all duration-300 hover:bg-primary-dim hover:shadow-[0_0_32px_rgba(240,118,33,0.3)] disabled:opacity-60"
      >
        <span id="btn-text">{contact.submit}</span>
        <div id="loading-spinner" class="hidden">
          <div class="h-4 w-4 animate-spin rounded-full border-2 border-white/30 border-t-white"></div>
        </div>
      </button>
    </form>

    <!-- Feedback messages -->
    <div id="success-message" class="relative mt-5 hidden rounded-xl border border-green-500/20 bg-green-500/10 p-4 text-sm text-green-400">
      <button id="close-success" class="absolute top-3 right-3 text-green-400/60 hover:text-green-400">✕</button>
      <p class="pr-6">{contact.success}</p>
    </div>
    <div id="error-message" class="relative mt-5 hidden rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-sm text-red-400">
      <button id="close-error" class="absolute top-3 right-3 text-red-400/60 hover:text-red-400">✕</button>
      <p class="pr-6">{contact.error}</p>
    </div>
  </div>
</section>

<script define:vars={{ contact }}>
  function setupContactForm() {
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const btnText = document.getElementById("btn-text");
    const loadingSpinner = document.getElementById("loading-spinner");
    const successMessage = document.getElementById("success-message");
    const errorMessage = document.getElementById("error-message");
    const closeSuccessBtn = document.getElementById("close-success");
    const closeErrorBtn = document.getElementById("close-error");

    if (!form) return;

    closeSuccessBtn?.addEventListener("click", () => successMessage?.classList.add("hidden"));
    closeErrorBtn?.addEventListener("click", () => errorMessage?.classList.add("hidden"));

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      if (submitBtn) submitBtn.disabled = true;
      if (btnText) btnText.textContent = contact.sending;
      loadingSpinner?.classList.remove("hidden");
      successMessage?.classList.add("hidden");
      errorMessage?.classList.add("hidden");

      setTimeout(() => {
        successMessage?.classList.remove("hidden");
        form.reset();
        if (submitBtn) submitBtn.disabled = false;
        if (btnText) btnText.textContent = contact.submit;
        loadingSpinner?.classList.add("hidden");
        setTimeout(() => successMessage?.classList.add("hidden"), 8000);
      }, 1000);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupContactForm);
  } else {
    setupContactForm();
  }

  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add("visible")),
    { threshold: 0.1 }
  );
  document.querySelectorAll(".animate-on-scroll").forEach(el => observer.observe(el));
</script>
