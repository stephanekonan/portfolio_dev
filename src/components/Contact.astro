---
// Contact component
import { t } from "../locales";

interface Props {
  lang: "fr" | "en";
}

const { lang } = Astro.props;
const contact = t(lang).contact;
---

<section class="py-16">
  <div class="mx-auto max-w-xl px-4">
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-bold text-white">{contact.title}</h2>
      <p class="text-lg text-white">
        {contact.subtitle}
      </p>
    </div>

    <form id="contact-form" class="space-y-6" action="/api/contact" method="POST">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-white"
            >{contact.name}
            <span class="text-red-500">{contact.required}</span></label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-white focus:border-transparent focus:ring-2 focus:ring-orange-500"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-white"
            >{contact.email}
            <span class="text-red-500">{contact.required}</span></label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-white focus:border-transparent focus:ring-2 focus:ring-orange-500"
          />
        </div>
      </div>

      <div>
        <label for="subject" class="mb-2 block text-sm font-medium text-white"
          >{contact.subject}
          <span class="text-red-500">{contact.required}</span></label
        >
        <input
          type="text"
          id="subject"
          name="subject"
          required
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-white focus:border-transparent focus:ring-2 focus:ring-orange-500"
        />
      </div>

      <div>
        <label for="message" class="mb-2 block text-sm font-medium text-white"
          >{contact.message}
          <span class="text-red-500">{contact.required}</span></label
        >
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full resize-none rounded-lg border border-gray-300 px-3 py-2 text-white focus:border-transparent focus:ring-2 focus:ring-orange-500"
        ></textarea>
      </div>

      <div class="text-center">
        <button
          type="submit"
          id="submit-btn"
          class="mx-auto flex cursor-pointer items-center justify-center rounded-lg bg-orange-600 px-8 py-3 font-semibold text-white transition-colors duration-200 hover:bg-orange-700"
        >
          <span id="btn-text">{contact.submit}</span>
          <div id="loading-spinner" class="ml-2 hidden">
            <div
              class="h-5 w-5 animate-spin rounded-full border-b-2 border-white"
            >
            </div>
          </div>
        </button>
      </div>
    </form>

    <div
      id="success-message"
      class="relative mt-6 hidden rounded-lg border border-green-400 bg-green-100 p-4 text-green-700"
    >
      <button
        id="close-success"
        class="absolute top-2 right-2 text-green-600 transition-colors duration-200 hover:text-green-800"
        aria-label={contact.close}
      >
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <p class="pr-8">{contact.success}</p>
    </div>
    <div
      id="error-message"
      class="relative mt-6 hidden rounded-lg border border-red-400 bg-red-100 p-4 text-red-700"
    >
      <button
        id="close-error"
        class="absolute top-2 right-2 text-red-600 transition-colors duration-200 hover:text-red-800"
        aria-label={contact.close}
      >
        <svg
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L6 6M6 6l12 12"></path>
        </svg>
      </button>
      <p class="pr-8">{contact.error}</p>
    </div>
  </div>
</section>

<script define:vars={{ contact }}>
  function setupContactForm() {
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("submit-btn");
    const btnText = document.getElementById("btn-text");
    const loadingSpinner = document.getElementById("loading-spinner");
    const successMessage = document.getElementById("success-message");
    const errorMessage = document.getElementById("error-message");
    const closeSuccessBtn = document.getElementById("close-success");
    const closeErrorBtn = document.getElementById("close-error");

    if (
      !form ||
      !submitBtn ||
      !btnText ||
      !loadingSpinner ||
      !successMessage ||
      !errorMessage ||
      !closeSuccessBtn ||
      !closeErrorBtn
    ) {
      console.error("Some form elements not found");
      return;
    }

    function hideMessages() {
      successMessage.classList.add("hidden");
      errorMessage.classList.add("hidden");
    }

    closeSuccessBtn.addEventListener("click", function () {
      successMessage.classList.add("hidden");
    });

    closeErrorBtn.addEventListener("click", function () {
      errorMessage.classList.add("hidden");
    });

    function autoHideMessage(messageElement) {
      setTimeout(() => {
        if (!messageElement.classList.contains("hidden")) {
          messageElement.classList.add("hidden");
        }
      }, 8000);
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();

      submitBtn.disabled = true;
      btnText.textContent = contact.sending;
      loadingSpinner.classList.remove("hidden");

      hideMessages();

      setTimeout(() => {
        successMessage.classList.remove("hidden");
        autoHideMessage(successMessage);

        form.reset();

        submitBtn.disabled = false;
        btnText.textContent = contact.submit;
        loadingSpinner.classList.add("hidden");
      }, 1000);
    });
  }

  // Initialize form when DOM is loaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupContactForm);
  } else {
    setupContactForm();
  }
</script>
