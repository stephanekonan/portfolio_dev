---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";
import { t } from "../locales";
import ProjectsItem from "./ProjectsItem.astro";

interface Props {
  projects: ProjectProps[];
  lang: "fr" | "en";
}

const { projects, lang } = Astro.props;
const i18n = t(lang).projects;

const merged = projects.map((p, i) => ({
  ...p,
  name: i18n.items[i]?.name ?? p.name,
  summary: i18n.items[i]?.summary ?? p.summary,
}));
---

<Section text={i18n.title} href="projects">
  {
    merged.map((p, index) => (
      <ProjectsItem
        name={p.name}
        summary={p.summary}
        image={p.image}
        linkSource={p.linkSource}
        linkPreview={p.linkPreview}
        index={index}
        lang={lang}
      />
    ))
  }
</Section>
